# Gemini API key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Live model — update to the latest available Live model
# Candidates: gemini-2.0-flash-live-001 | gemini-live-2.5-flash-preview-native-audio-dialog
GEMINI_MODEL=gemini-2.0-flash-live-001

# Gateway listen port
PORT=8765

# Comma-separated allowed browser origins for CORS / WS upgrade
ALLOWED_ORIGINS=http://localhost:5173,https://romeoflexvision.com
