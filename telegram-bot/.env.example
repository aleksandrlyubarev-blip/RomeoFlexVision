# Required — obtain from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Production webhook settings (leave empty to use long polling in dev)
# WEBHOOK_DOMAIN must be an HTTPS URL accessible from the internet, e.g. https://api.example.com
WEBHOOK_DOMAIN=

# A random secret appended to the webhook path to prevent unauthorised calls
TELEGRAM_WEBHOOK_SECRET=

# HTTP port the Express server listens on (default: 3000)
PORT=3000

NODE_ENV=development
